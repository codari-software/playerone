generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?    @unique
  password      String?
  isGuest       Boolean   @default(false)
  isVerified    Boolean   @default(false)
  image         String?
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime  @default(now())
  plan          Plan      @default(INICIANTE)
  activeModule  Module?
  
  // RPG Stats
  energy        Int       @default(100)
  maxEnergy     Int       @default(100)
  power         Int       @default(10)
  strength      Int       @default(5)
  intelligence  Int       @default(5)
  constitution  Int       @default(5)
  willpower     Int       @default(5)
  
  characterClass CharacterClass?
  characterSkin  String?
  gender         String?
  
  nickname      String?   @unique
  weight        Float?
  hasCompletedTutorial Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  habits              Habit[]
  financeTransactions FinanceTransaction[]
  healthLogs          HealthLog[]
  workouts           Workout[]
  userAchievements    UserAchievement[]
  recurringBills      RecurringBill[]
  inventory           UserItem[]
  sessions            Session[]
  accounts            Account[]
  notes               Note[]
  bossProgress        UserBoss[]
  bossObjectives      UserBossObjective[]
}

enum CharacterClass {
  WARRIOR
  MAGE
  ARCHER
}

enum Plan {
  INICIANTE
  HERO
  LEGEND
}

enum Module {
  HABITS
  FINANCES
  HEALTH
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  xpReward    Int      @default(10)
  frequency   Frequency @default(DAILY)
  isCompleted Boolean  @default(false)
  streak      Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  completed Boolean  @default(true)

  @@index([habitId])
  @@index([date])
}


enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

model FinanceTransaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Float
  category    String
  description String?
  date        DateTime          @default(now())
  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([date])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model HealthLog {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         HealthType
  value        Float
  unit         String
  description  String?
  xpEarned     Int        @default(5)
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([date])
}

enum HealthType {
  EXERCISE
  WATER
  SLEEP
}

model Workout {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String     // Ex: Treino A, Peito e Triceps
  date        DateTime   @default(now())
  exercises   Exercise[]
  createdAt   DateTime   @default(now())

  @@index([userId])
}

model Exercise {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name        String
  sets        Set[]
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Set {
  id          String   @id @default(cuid())
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  reps        Int?
  weight      Float?
  isCompleted Boolean  @default(false)
}

model Achievement {
  id               String            @id @default(cuid())
  name             String
  description      String
  icon             String
  xpReward         Int               @default(50)
  requirement      String
  requirementValue Int
  category         String
  createdAt        DateTime          @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RecurringBill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  amount      Float
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model AvatarItem {
  id          String   @id @default(cuid())
  name        String
  type        ItemType
  priceXP     Int
  rarity      String   @default("COMMON")
  imageUrl    String?
  createdAt   DateTime @default(now())
  
  users       UserItem[]
}

model UserItem {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId       String
  item         AvatarItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  isEquipped   Boolean     @default(false)
  unlockedAt   DateTime    @default(now())

  @@unique([userId, itemId])
  @@index([userId])
}

enum ItemType {
  SKIN
  WEAPON
  SHIELD
  HAT
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Boss {
  id           String      @id @default(cuid())
  name         String
  description  String
  level        Int
  hp           Int
  xpReward     Int
  difficulty   Int         // 1-10
  imageUrl     String?
  order        Int         @unique // 1, 2, 3, 4, 5
  
  userProgress UserBoss[]
  objectives   BossObjective[]
}

model BossObjective {
  id          String   @id @default(cuid())
  bossId      String
  boss        Boss     @relation(fields: [bossId], references: [id], onDelete: Cascade)
  description String
  hpDamage    Int      // Dano causado ao HP do boss ao completar
  
  userCompletions UserBossObjective[]
}

model UserBossObjective {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  objectiveId     String
  objective       BossObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  isCompleted     Boolean  @default(false)
  completedAt     DateTime?

  @@unique([userId, objectiveId])
  @@index([userId])
}

model UserBoss {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossId      String
  boss        Boss     @relation(fields: [bossId], references: [id], onDelete: Cascade)
  status      String   @default("LOCKED") // LOCKED, UNLOCKED, DEFEATED
  lastDefeatedAt DateTime?

  @@index([userId])
  @@index([bossId])
  @@unique([userId, bossId])
}
